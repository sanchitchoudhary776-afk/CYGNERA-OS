# ============================================
# AXINITE OS — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Groq AI (Free tier: Llama 3.3 70B + Llama 3.1 8B)
# Get your key at: https://console.groq.com/keys
# Note: You can provide multiple comma-separated keys to multiply your rate limit!
# Example: VITE_GROQ_API_KEY=key1,key2,key3
VITE_GROQ_API_KEY=your_groq_api_key_here

# Backend API
VITE_API_BASE_URL=http://localhost:5000/api

# Supabase (Database & Auth)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App Config
VITE_APP_NAME=AXINITE OS
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
